#!/bin/bash
YELLOW='\033[1;33m'
NC='\033[0m'
echo -e "${YELLOW}USB 裝置 (USB Devices)${NC}"
if [[ "$(uname)" == "Darwin" ]]; then
    system_profiler SPUSBDataType | grep "Product ID" -B 1 | grep -v "Product ID" | grep -v "\-\-" | sed 's/^[[:space:]]*//' | sed 's/://' | sed 's/^/- /'
else
    lsusb | cut -d: -f3- | sed 's/^/- /'
fi

#!/bin/bash
YELLOW='\033[1;33m'
NC='\033[0m'
echo -e "${YELLOW}顯示卡 (GPU)${NC}"
if [[ "$(uname)" == "Darwin" ]]; then
    system_profiler SPDisplaysDataType | grep "Chipset Model" | head -n 1 | sed 's/Chipset Model:/- GPU Model:/' | sed 's/^[[:space:]]*//'
else
    lspci | grep -i vga | cut -d: -f3 | sed 's/^ /- GPU Model:/'
fi

[init]
	defaultbranch = master
[user]
	name = shuk.liu
	# Phase 7.3: email 移至個人層級 (`git config --global user.email "<your-email>"`)
	# 此檔追蹤的 .gitconfig 不再 commit 真實 email；保留 `name` 與 `signingkey` 作為共同基礎。
	signingkey = ~/.ssh/id_ed25519.pub
[merge]
	log = 25
[color]
	log = auto
	diff = auto
	status = auto
	branch = auto
	ui = true
[alias]
	clone = clone --depth 10
	co = checkout
	ci = commit
	st = status
    br = branch
    ca = cat-file
    lt = ls-tree -r
    lr = ls-remote
    lf = ls-files
    push = push --follow-tags
	logv = log --name-status --graph --decorate
	rollback = checkout
[pack]
	windowMemory = 25m
	SizeLimit = 25m
	threads = 1
[log]
	date = local
[core]
	editor = vim
	quotepath = false
	excludesFile = /Users/shuk/.gitignore
[credential]
    helper = cache --timeout=3600
#    helper = store         # save credential forever , with option "--file <file>"
[http]
	sslVerify = true
[push]
    default = current
[pull]
    rebase = true
[commit]
    template = ~/.gitmessage
	gpgsign = true

[pull]
	rebase = true
[url "gitr"]
    insteadOf = git://git.byted.org/
[credential "https://code.byted.org"]
    username = shuk.liu
[url "ssh://shuk.liu@git.byted.org:29418"]
    insteadOf = https://git.byted.org
[url "git@code.byted.org:"]
    insteadOf = https://code.byted.org/
[safe]
	directory = *
[gpg]
	format = ssh

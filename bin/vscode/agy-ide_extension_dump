#!/usr/bin/env bash

# Script to dump agy-ide extensions to a text file
# This allows for easy re-installation or tracking of extensions

set -euo pipefail

# Define the target location
TARGET_FILE="${HOME}/projects/env_setup/bin/vscode/agy-ide_extension_list.txt"
TARGET_DIR=$(dirname "${TARGET_FILE}")

# Ensure the directory exists
mkdir -p "${TARGET_DIR}"

echo "Dumping agy-ide extensions to: ${TARGET_FILE}"

# Check if 'agy-ide' command is available
if ! command -v agy-ide >/dev/null 2>&1; then
    echo "❌ Error: 'agy' command not found in PATH."
    echo "Please ensure you have installed the agy-ide CLI. Open IDE cmd+shift+p => Shell Command Install 'agy-ide' command in the PATH"
    exit 1
fi

# Run agy extension list and save to target file
# Assuming 'agy-ide extension list' is the command. If not, this needs to be updated.
agy-ide --list-extensions > "${TARGET_FILE}"

echo "✅ agy-ide extensions successfully dumped to: ${TARGET_FILE}"
echo "Total extensions: $(wc -l < "${TARGET_FILE}")"
echo ""
echo "To re-install these extensions later, you can run:"
echo "  xargs -L 1 agy-ide --install-extension < ${TARGET_FILE}"
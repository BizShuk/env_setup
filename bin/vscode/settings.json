{
    "window.title": "${activeEditorFull}${separator}${rootName}",
    "window.openFoldersInNewWindow": "on",
    // [workbench]
    "workbench.startupEditor": "none",
    "workbench.colorCustomizations": {
        // 衝突 (Conflicted) 的顏色
        "gitDecoration.conflictingResourceForeground": "#FF0000",
        "gitDecoration.addedResourceForeground": "#00ff41",
        "gitDecoration.untrackedResourceForeground": "#00d4ff",
        "gitDecoration.deletedResourceForeground": "#FF0000",
        "gitDecoration.modifiedResourceForeground": "#00ffcc", // 使用顯眼的青色

        // 2. 調整 Submodule (或其他資源) 的狀態顏色，這有時會影響 Staged 檔案的顯示
        "gitDecoration.stageModifiedResourceForeground": "#00ffcc",
        "editorOverviewRuler.addedForeground": "#00ff41",
        "editorOverviewRuler.modifiedForeground": "#ffcc00",
        "editorOverviewRuler.deletedForeground": "#ff4444"
        // // === 深色主題：刪除區域設定 (Dark-Theme Removed Colors) ===
        // // 刪除行的整行背景：採用低飽和暗紅（透明度約 8%），當作舒適的背景底色
        // "diffEditor.removedLineBackground": "#da4c4c14",
        // // 具體刪除字元的背景：稍微加深（透明度 22%），精準鎖定被刪除的字
        // "diffEditor.removedTextBackground": "#da4c4c38",
        // // 刪除字元的邊框：用淡淡的紅框鎖定字元，避免深色背景下模糊
        // "diffEditor.removedTextBorder": "#da4c4c45",

        // // === 深色主題：新增區域設定 (Dark-Theme Inserted Colors) ===
        // // 新增行的整行背景：採用低飽和暗綠（透明度約 8%），不與程式碼高亮衝突
        // "diffEditor.insertedLineBackground": "#2ea04314",
        // // 具體新增字元的背景：稍微加深（透明度 22%）
        // "diffEditor.insertedTextBackground": "#2ea04338",
        // // 新增字元的邊框：用淡淡的綠框輔助視覺定錨
        // "diffEditor.insertedTextBorder": "#2ea04345",

        // // === 側邊行號區與捲軸提示 (Gutter & Ruler) ===
        // // 程式碼左側行號邊欄 (Gutter) 的刪除與新增指示條（調低亮度避免過閃）
        // "diffEditorGutter.removedLineBackground": "#da4c4c88",
        // "diffEditorGutter.insertedLineBackground": "#2ea04388",
        // // 右側導覽捲軸 (Overview Ruler) 的標記顏色，維持點綴即可
        // "diffEditorOverviewRuler.removedForeground": "#da4c4c66",
        // "diffEditorOverviewRuler.insertedForeground": "#2ea04366"
    },
    "workbench.auxiliaryActivityBar.location": "default",
    "workbench.editor.tabActionLocation": "right",
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.md": "default",
        "*.mm.md": "markmap-vscode.markmap",
        "*.markdown": "default",
        "*.csv": "default",
        "*.mp4": "analyticsignal.preview-mp4"
    },
    "workbench.tree.renderIndentGuides": "always",
    "workbench.tree.expandMode": "singleClick",
    "workbench.tree.indent": 8,
    "workbench.tree.enableStickyScroll": true,
    "workbench.tree.stickyScrollMaxItemCount": 2,
    // [security]
    "security.workspace.trust.untrustedFiles": "open",
    "security.promptForRemoteFileProtocolHandling": false,
    // [explorer]
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,
    "explorer.excludeGitIgnore": false,
    "explorer.openEditors.visible": 2,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "*.json,*.ts",
        "Makefile": "Makefile*",
        ".env": ".env.*,",
        "main.go": "go.mod,handler.go",
        "go.mod": "go.sum",
        "*.go": "${capture}_test.go,${capture}_string.go,${capture}.sql,${capture}*.jsonc,${capture}*.md,.env*,${capture}*.tmpl,${capture}.csv",
        "*.md": "${capture}*.md",
        "*.sh": "${capture}*.md",
        "README.md": "LICENSE,.gitignore,.pre-commit-config.yaml,sample_markdown.md,GEMINI.md,AGENTS.md,CLAUDE.md,.geminiignore,.gitmodules,build.sh,run.sh,daemon.sh,docker-compose.yml,Dockerfile,crontab.*,dashboard*,ecosystem.config.js,.markdownlint*,local.sql,README.todo",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "editor.autoIndent": "advanced",
    "editor.codeActions.triggerOnFocusChange": true,
    "editor.comments.insertSpace": true,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.find.seedSearchStringFromSelection": "selection",
    "editor.fontSize": 12,
    "editor.formatOnSave": true,
    "editor.inlineSuggest.edits.showCollapsed": true,
    "editor.inlineSuggest.enabled": true,
    "editor.insertSpaces": true,
    "editor.lineNumbers": "on",
    "editor.linkedEditing": true,
    "editor.minimap.renderCharacters": false,
    "editor.minimap.showSlider": "always",
    "editor.minimap.size": "fit",
    "editor.showFoldingControls": "always",
    "editor.snippetSuggestions": "inline",
    "editor.tabCompletion": "on",
    "editor.tabSize": 4,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 200,
    "editor.quickSuggestions": {
        "comments": "on",
        "strings": "on",
        "other": "on"
    },
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit",
        "source.fixAll.gemini": "never"
    },
    // [scm]
    "scm.defaultViewMode": "tree",
    "scm.diffDecorations": "all",
    "scm.diffDecorationsGutterWidth": 5,
    "scm.diffDecorationsGutterVisibility": "always",

    // [diff editor]
    "diffEditor.ignoreTrimWhitespace": true,
    "diffEditor.codeLens": true,
    "diffEditor.renderSideBySide": true,
    "diffEditor.useInlineViewWhenSpaceIsLimited": true,
    "diffEditor.hideUnchangedRegions.enabled": true,
    // [files]
    "files.autoSave": "off",
    "files.eol": "\n",
    "files.exclude": {
        // 系統與中繼資料 (System & Metadata - Human non-readable)
        "{.DS_Store,Thumbs.db,**/.svn,**/.hg}": true,
        // 專案快取與套件依賴 (Dependencies & Caches)
        "{**/node_modules,**/__pycache__,**/.venv,**/.mvn}": true,
        // 建置產出與自動產生代碼 (Build Artifacts & Generated Code)
        "{**/gen,**/kitex_gen,**/thrift_gen,**/target,**/out,**/dist,**/output,**/__debug_bin*}": true,
        // 版本控制與工作區設定 (Version Control & Workspace Configs)
        "{**/.git,**/.geminiignore,**/.gitlab,.pre-commit-config.yaml}": true,
        // IDE 與開發工具設定 (IDE & Tool Settings)
        "{**/.classpath,**/.project,**/.settings,**/.antigravity,**/.playwright-cli,**/.devops}": true,
        // 備份與封存 (Backups & Archives)
        "{*.bak*}": true,
        // AI 智能體配置 (AI Agents Meta)
        "{**/AGENTS.md,**/GEMINI.md}": true,
        "{**/.agents}": false,
        // 測試與非必要文件 (Tests & Documentation)
        "{**/*_test.go,go.sum}": true
    },
    "files.watcherExclude": {
        // 依賴與快取 (Dependencies & Caches)
        "{**/node_modules,**/.venv,**/.vim,**/__pycache__,**/.cache}": true,
        // 建置與產出 (Build & Release Outputs)
        "{**/dist,**/_output,**/build,**/out,**/output,**/release,**/releases,**/target,**/.next,**/.nuxt,**/__debug_bin*}": true,
        // 程式產生代碼 (Generated Code)
        "{**/gen,**/kitex_gen,**/thrift_gen}": true,
        // 領域與系統目錄 (Domains & System Directories)
        "{**/.git/objects/**,**/.git/subtree-cache/**,**/homebrew,**/archive}": true,
        // 媒體與二進位資源 (Media & Binary Assets)
        "**/*.{map,3ds,3g2,3gp,7z,a,aac,adp,ai,aif,aiff,alz,ape,apk,ar,arj,asf,au,avi,bak,baml,bh,bk,bmp,btif,bz2,bzip2,cab,caf,cgm,class,cmx,cpio,cr2,csv,cur,dat,dcm,deb,dex,djvu,dll,dmg,dng,doc,docm,docx,dot,dotm,dra,dsk,dts,dtshd,dvb,dwg,dxf,ecelp4800,ecelp7470,ecelp9600,egg,eol,eot,epub,exe,f4v,fbs,fh,fla,flac,fli,flv,fpx,fst,fvt,g3,gif,graffle,gz,gzip,h261,h263,h264,icns,ico,ief,img,ipa,iso,jar,jpeg,jpg,jpgv,jpm,jxr,key,ktx,lha,lib,lvp,lz,lzh,lzma,lzo,m3u,m4a,m4v,mar,mdi,mht,mid,midi,mj2,mka,mkv,mmr,mng,mobi,mov,movie,mp3,mp4,mp4a,mpeg,mpg,mpga,mxu,nef,npx,numbers,o,oga,ogg,ogv,otf,pages,pbm,pcx,pdb,pdf,pea,pgm,pic,png,pnm,pot,potm,potx,ppa,ppam,ppm,pps,ppsm,ppsx,ppt,pptm,pptx,psd,pya,pyc,pyo,pyv,qt,rar,ras,raw,resources,rgb,rip,rlc,rmf,rmvb,rtf,rz,s3m,s7z,scpt,sgi,shar,sil,sketch,slk,smv,so,sub,swf,tar,tbz,tbz2,tga,tgz,thmx,tif,tiff,tlz,ttc,ttf,txz,udf,uvh,uvi,uvm,uvp,uvs,uvu,viv,vob,war,wav,wax,wbmp,wdp,weba,webm,webp,whl,wim,wm,wma,wmv,wmx,woff,woff2,wvx,xbm,xif,xla,xlam,xls,xlsb,xlsm,xlsx,xlt,xltm,xltx,xm,xmind,xpi,xpm,xwd,xz,z,zip,zipx,JPG,MOV,MP4,msg,msi,vcp,PDF,TTF}": true
    },
    "files.associations": {
        ".env*": "dotenv",
        "{*.sh,*.info}": "shellscript",
        "*.bosun": "bosun",
        "*.ignore": "gitignore",
        "{*.timer,*.service}": "ini",
        "{*.plan,*.ignore,*.todo}": "markdown",
        "LICENSE": "plaintext"
    },
    // [search]
    "search.useIgnoreFiles": true,
    "search.followSymlinks": false,
    "search.exclude": {
        // 繼承自 files.exclude (Inherited from files.exclude)
        "/var/folders": true,
        "**/plans": true,
        "**/docs": true,
        "**/logs": true,
        // 鎖定檔與二進位檔案排除 (Lockfiles & Caches Exclude)
        "{go.sum,package-lock.json,pnpm-lock.yaml,yarn.lock}": true
    },
    "search.showLineNumbers": true,
    "search.collapseResults": "auto",
    // "search.smartCase": true,
    // [Debug]
    "debug.toolBarLocation": "floating",
    "debug.console.fontSize": 14,
    "launch": {
        "version": "0.2.0",
        "configurations": [
            {
                "name": "Go Launch Project",
                "type": "go",
                "request": "launch",
                "mode": "debug",
                "program": "${workspaceFolder}",
                "envFile": "${userHome}/.env"
            },
            {
                "name": "Go Launch file",
                "type": "go",
                "request": "launch",
                "mode": "debug",
                "program": "${file}"
                // "envFile": "${userHome}/.env",
            },
            {
                "name": "Launch Chrome",
                "request": "launch",
                "type": "chrome",
                "url": "http://localhost:3000",
                "webRoot": "${workspaceFolder}"
            },
            {
                // Should setup ts-node `npm i -d ts-node; npm i -g typescript`
                "type": "node",
                "name": "ts file",
                "request": "launch",
                "runtimeArgs": ["-r", "ts-node/register"],
                "program": "${file}",
                "envFile": "${userHome}/.env"
            },
            {
                "name": "Python: Current File",
                "type": "debugpy",
                "request": "launch",
                "program": "${file}",
                "console": "internalConsole",
                "python": "${command:python.interpreterPath}"
            }
        ],
        "compounds": []
    },
    "editor.fontFamily": "SF Mono",
    // [terminal]
    "terminal.integrated.fontSize": 12,
    "terminal.integrated.fontFamily": "monospace",
    "terminal.integrated.copyOnSelection": true,
    // "terminal.integrated.tabs.title": "${process} ${task}",
    "terminal.integrated.tabs.title": "${sequence}",
    "terminal.integrated.tabs.description": "${task}${separator}${cwdFolder}",
    "terminal.integrated.commandsToSkipShell": [
        "editor.action.rename",
        "workbench.action.terminal.rename",
        "workbench.action.toggleEditorWidths",
        "workbench.action.nextEditor",
        "workbench.action.createTerminalEditor",
        "workbench.action.nextEditor",
        "workbench.action.openEditorAtIndex3",
        "workbench.action.openEditorAtIndex4",
        "workbench.action.terminal.rename"
    ],
    "terminal.integrated.macOptionIsMeta": true,
    "terminal.integrated.mouseWheelScrollSensitivity": 3,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.defaultProfile.osx": "bash",
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.suggest.quickSuggestions": {
        "commands": "on",
        "arguments": "on",
        "unknown": "off"
    },
    "terminal.integrated.enableVisualBell": true,
    "terminal.integrated.suggest.enabled": true,
    "terminal.integrated.suggest.providers": {
        "lsp": true
    },
    "accessibility.signals.terminalBell": {
        "sound": "on",
        "announcement": "auto"
    },
    // [git]
    "git.autofetch": true,
    "git.autofetchPeriod": 1800,
    "git.autoStash": true,
    "git.confirmSync": false,
    "git.detectSubmodules": false,
    "git.enableSmartCommit": true,
    "git.fetchOnPull": true,
    "git.followTagsWhenSync": true,
    "git.ignoreMissingGitWarning": true,
    "git.ignoreSubmodules": true,
    "git.openRepositoryInParentFolders": "always",
    "git.pruneOnFetch": true,
    "git.showPushSuccessNotification": true,
    "git.untrackedChanges": "separate",
    "git.blame.editorDecoration.enabled": false,
    "git.blame.statusBarItem.enabled": false,
    // [go]
    "go.toolsManagement.autoUpdate": true,
    "go.diagnostic.vulncheck": "Off", // ???
    "go.useLanguageServer": true,
    // ... other settings ...
    "gopls": {
        "ui.completion.usePlaceholders": true,
        "formatting.gofumpt": true,
        "build.directoryFilters": [
            "-**/lib/go/pkg",
            "-node_modules",
            "-__pycache__"
        ],
        // "ui.navigation.diagnosticFilters": [
        //     "-**/lib/go/pkg",
        //     "-node_modules",
        //     "-__pycache__"
        // ],
        "analyses": {}
    },
    "go.buildFlags": ["-gcflags=-m -l"],
    "go.lintTool": "golangci-lint",
    // "go.lintTool": "golangci-lint", // [go linter]
    // "go.formatTool": "custom",
    // "go.formatTool": "goimports",
    "go.lintFlags": ["--path-mode=abs", "--fast-only"],
    "go.alternateTools": {
        "customFormatter": "golangci-lint-v2"
    },
    "go.formatFlags": ["fmt", "--stdin"],
    // [go test]
    "go.testOnSave": true,
    "go.testExplorer.showOutput": false,
    "go.testFlags": ["-v", "-race", "-count=1"],
    // [go cover]
    "go.coverShowCounts": true,
    "go.coverOnSave": true,
    "go.coverOnSingleTest": true,
    "go.coverageOptions": "showBothCoveredAndUncoveredCode",
    "go.coverOnSingleTestFile": false,
    "go.coverOnTestPackage": false,
    // "go.coverMode": "count", // ???
    "go.coverageDecorator": {
        "type": "gutter",
        "coveredGutterStyle": "blockblue",
        "uncoveredGutterStyle": "slashred"
    },
    // [javascript] [npm] [node] [typescript] [js] [jest]
    "javascript.updateImportsOnFileMove.enabled": "always",
    // [Markdown]
    // "markdown.styles": [
    //     "https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css"
    // ]
    "markdown.copyFiles.destination": {
        "**/*": "assets/images/md/${documentBaseName}-${fileName}"
    },
    "markdownlint.config": {
        "default": true,
        "MD001": false,
        "MD007": {
            "indent": 4
        },
        "MD009": {
            "br_spaces": 2
        },
        "MD024": false,
        "MD025": false,
        "MD028": false,
        "MD029": false,
        "MD033": false,
        "MD036": false,
        "MD045": false,
        "MD053": false,
        "MD059": false,
        "SA9003": false
    },
    // [highlight] [todo]
    "highlight.regexes": {
        // $, S$
        "([S]{0,1}\\$)": [
            {
                "color": "#FFFF00"
            }
        ],
        // # test
        "(#)": [
            {
                "color": "#00FF00"
            }
        ],
        // [xxx]
        "(\\[.+?\\])": [
            {
                "color": "#FFFF00"
            }
        ],
        // ===== xxx =====
        "(===== )(.+?)( =====)": [
            {},
            {
                "color": "#FFFF00",
                "fontWeight": "bold",
                "fontStyle": "italic"
            },
            {}
        ],
        // <xxx>
        "(\\<.+?\\>)": [
            {
                "color": "#FFA500"
            }
        ],
        // "xxx"
        "(\".+?\")": [
            {
                "color": "#FFA500"
            }
        ],
        // 'xxx'
        "('.+?')": [
            {
                "color": "#FFA500"
            }
        ],
        // `xxx`
        "(`.+?`)": [
            {
                "color": "#FFA500"
            }
        ],
        // *xxx*
        "(\\*+.+?\\*)": [
            {},
            {
                "color": "#FFFFFF"
            },
            {}
        ],
        // {xxx}
        "({\\S+?})": [
            {
                "color": "#FFA500"
            }
        ],
        // {xxx}
        "({{.+?}})": [
            {
                "color": "#FFA500"
            }
        ],
        // Warning: xxx
        "(Warning)(:)(.*)": [
            {
                "color": "#FFC0CB",
                "fontWeight": "bold"
            },
            {},
            {
                "color": "#FF0000",
                "fontWeight": "bold"
            }
        ],
        // TODO: xxx
        "(TODO)(:)": [
            {
                "color": "#FFFFFF",
                "fontWeight": "bold"
            },
            {}
        ],
        // NOTE: xxx
        "(NOTE)(:)": [
            {
                "color": "#FFFF00",
                "fontWeight": "bold"
            },
            {}
        ],
        // BUG: xxx
        "(BUG|FIX|FIXME|ISSUE)(:)": [
            {
                "color": "#FF0000"
            },
            {}
        ],
        // ???
        "(\\?+)": [
            {
                "color": "#FF0000",
                "fontWeight": "bold"
            }
        ],
        // @xxx
        "(\\@)([\\S]+)": [
            {
                "color": "#808080"
            },
            {
                "color": "#00FF00"
            }
        ],
        // ====>
        "(=+>)": [
            {
                "color": "#00FF00"
            }
        ],
        // #asdasji
        "(#)([^#\\s]+)": [
            // Hash Tag
            {
                "color": "#808080"
            },
            {
                "color": "#FFFFFF"
            }
        ]
    },
    // [github]
    "githubPullRequests.pushBranch": "always",
    "githubIssues.queries": [
        {
            "label": "My Issues",
            "query": "is:issue state:open archived:false assignee:${owner} repo:${owner}/${repository} sort:updated-desc"
        },
        {
            "label": "Repo Issues",
            "query": "is:issue state:open archived:false repo:${owner}/${repository} sort:updated-desc"
        },
        {
            "label": "Created Issues",
            "query": "author:${user} state:open sort:created-desc"
        },
        {
            "label": "Recent Issues",
            "query": "is:issue state:open user:${user} sort:updated-desc"
        }
    ],
    "githubPullRequests.queries": [
        {
            "label": "Local Pull Request Branches",
            "query": "default"
        },
        {
            "label": "Waiting For My Review",
            "query": "repo:${owner}/${repository} is:open review-requested:${user}"
        },
        {
            "label": "Assigned To Me",
            "query": "repo:${owner}/${repository} is:open assignee:${user}"
        },
        {
            "label": "Created By Me",
            "query": "repo:${owner}/${repository} is:open author:${user}"
        },
        {
            "label": "All Open",
            "query": "repo:${owner}/${repository} is:open user:${user}"
        },
        {
            "label": "All Open",
            "query": "default"
        }
    ],
    // [Editor by Language]
    "[yaml]": {
        "editor.tabSize": 2,
        "prettier.tabWidth": 2,
        "editor.quickSuggestions": {
            "comments": false,
            "strings": true
        }
    },
    "[markdown]": {
        "files.trimTrailingWhitespace": false,
        "editor.trimWhitespaceOnDelete": false,
        "files.trimTrailingWhitespaceInRegexAndStrings": false,
        "editor.trimAutoWhitespace": false
    },
    "[todo]": {
        "files.trimTrailingWhitespace": false
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    // [shellcheck]
    "shellcheck.exclude": [
        "2002",
        "1090",
        "SC2155",
        "SC2156",
        "SC2086",
        "SC2206"
    ],
    "shellcheck.customArgs": ["-x"],
    // [Container]
    "containers.commands.run": "${containerCommand} run --rm -d ${exposedPorts} ${tag}",
    "containers.containerClient": "com.microsoft.visualstudio.containers.docker",
    "containers.orchestratorClient": "com.microsoft.visualstudio.orchestrators.dockercompose",
    "containers.containers.label": "ContainerName",
    "containers.containers.description": ["Image", "Ports", "Status"],
    "containers.containers.groupBy": "Compose Project Name",
    "containers.images.label": "RepositoryNameShort",
    "containers.images.description": ["Size"],
    "containers.images.groupBy": "Registry",
    "containers.images.sortBy": "Label",
    // SQLite
    "sqltools.useNodeRuntime": false,
    "sqltools.connections": [
        {

    {
        "key": "ctrl+alt+cmd+p", // 請替換為您想要的快捷鍵
        "command": "runCommands",
        "args": {
            "commands": [
                // 1. 開啟專案內的 CLAUDE.md (Group 1)

                {
                    "command": "vscode.open",
                    "args": ["/Users/shuk/projects/inf/CLAUDE.md"]
                },
                // 2. 向右拆分區塊 (焦點轉移到右側，建立 Group 2)
                "workbench.action.newGroupBelow",
                // 3. 在 Group 2 建立 terminal 並執行 claudem
                "workbench.action.createTerminalEditor",
                {
                    "command": "workbench.action.terminal.sendSequence",
                    "args": { "text": "claudem\n" }
                },
                // 4. 在 Group 2 向下拆分 (建立 Group 3)
                "workbench.action.newGroupRight",
                // // 5. 在 Group 3 建立 terminal 並執行 ncdu
                "workbench.action.createTerminalEditor",
                {
                    "command": "workbench.action.terminal.sendSequence",
                    "args": { "text": "ncdu\n" }
                },
                // // 6. 在 Group 3 再向下拆分 (建立 Group 4)
                "workbench.action.newGroupRight",
                // // 7. 在 Group 4 建立 terminal 並執行 port_listenor monitor
                "workbench.action.createTerminalEditor",
                {
                    "command": "workbench.action.terminal.sendSequence",
                    "args": { "text": "port_listenor monitor\n" }
                }
            ]
        }

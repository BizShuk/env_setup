{
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "0",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "0",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "OTEL_METRICS_EXPORTER": "otlp"
  },
  "attribution": {
    "commit": "Committed by AI",
    "pr": "Committed by AI"
  },
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(go build:*)",
      "Bash(python3:*)",
      "Bash(bytedcli *)",
      "Bash(gdpa-cli *)"
    ],
    "deny": [
      "Bash(git push *)",
      "Read(.env.key)",
      "Bash(rm *)"
    ],
    "ask": [],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "worktree": {
    "baseRef": "fresh"
  },
  "allowedHttpHookUrls": [
    "http://localhost:*"
  ],
  "httpHookAllowedEnvVars": [
    "MY_TOKEN",
    "HOOK_SECRET"
  ],
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "extraKnownMarketplaces": {
    "FlineDev": {
      "source": {
        "source": "github",
        "repo": "FlineDev/Marketplace"
      }
    }
  },
  "outputStyle": "Explanatory",
  "effortLevel": "high",
  "fastModePerSessionOptIn": true,
  "autoUpdatesChannel": "latest",
  "plansDirectory": "./plans",
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "autoMemoryEnabled": false,
  "theme": "dark-daltonized",
  "verbose": true,
  "teammateMode": "in-process"
}